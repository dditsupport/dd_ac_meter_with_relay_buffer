# Arduino IDE build artifacts
build/
*.bin
*.elf
*.map
*.hex

# OS junk
.DS_Store
Thumbs.db

# Editor cruft
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc
.venv/
venv/

# Backend: real secrets never leave the host
backend/public_html/_config/secrets.php
# Backend: PHP session files (app-private save_path resolves to backend/ in a
# local checkout; on the host it lives above public_html). Never commit these.
backend/meter_sessions/
meter_sessions/

# Android build / machine-specific (keep gradlew + gradle/wrapper)
android/**/local.properties
android/**/.gradle/
android/**/build/
