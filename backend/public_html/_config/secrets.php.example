<?php
// Copy this file to secrets.php and fill in the values.
// secrets.php is gitignored — never commit real credentials.
// .htaccess in this directory denies all web access.

declare(strict_types=1);

define('DB_HOST',  'localhost');
define('DB_NAME',  '<cpanel-prefix>_acmeter');
define('DB_USER',  '<cpanel-prefix>_acmeterapp');
define('DB_PASS',  '<strong-db-password>');

// Must match firmware's DEVICE_TOKEN macro in config.h.
define('DEVICE_TOKEN', 'hs2AfGYZqZSFbb_rp-t3zy_I_rXb5TJISpn6Okih4pg');

// Application time zone. Drives PHP's default zone (date('c'), wall_time
// formatting) AND the MySQL session zone (NOW()/CURRENT_TIMESTAMP columns),
// so everything is stored and displayed in one zone. Default: IST (+05:30).
define('APP_TIMEZONE', 'Asia/Kolkata');

// Default logging cadence pushed to devices that have no explicit override.
// Set to 0 to leave the firmware default in place. Otherwise in [60, 86400].
define('DEFAULT_LOG_INTERVAL_SEC', 900);

// Session lifetime in seconds for browser dashboard logins.
define('SESSION_LIFETIME', 60 * 60 * 8);
